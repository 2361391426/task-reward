{
  "name": "task-reward-backend",
  "version": "1.0.0",
  "description": "任务返现平台后端API - Vercel Serverless",
  "main": "index.js",
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "start:local": "node server-local.js",
    "check": "node scripts/check-config.js",
    "backup:local": "node scripts/backup-local.js",
    "cleanup:uploads": "node scripts/cleanup-uploads.js",
    "cleanup:uploads:weekly": "node scripts/cleanup-uploads.js --weekly",
    "smoke": "node scripts/smoke-test.js",
    "test:p2": "node scripts/p2-regression-test.js",
    "test": "npm run smoke"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.470.0",
    "@neondatabase/serverless": "^1.1.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "busboy": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "vercel": "^33.0.1"
  }
}
