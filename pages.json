{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "任务大厅",
        "enablePullDownRefresh": true,
        "backgroundTextStyle": "dark"
      }
    },
    {
      "path": "pages/task-detail/index",
      "style": {
        "navigationBarTitleText": "任务详情",
        "enablePullDownRefresh": true,
        "backgroundTextStyle": "dark"
      }
    },
    {
      "path": "pages/upload/index",
      "style": {
        "navigationBarTitleText": "上传截图",
        "enablePullDownRefresh": true,
        "backgroundTextStyle": "dark"
      }
    },
    {
      "path": "pages/my/index",
      "style": {
        "navigationBarTitleText": "我的",
        "enablePullDownRefresh": true,
        "backgroundTextStyle": "dark"
      }
    },
    {
      "path": "pages/profile/edit/index",
      "style": {
        "navigationBarTitleText": "编辑个人信息",
        "enablePullDownRefresh": false,
        "backgroundTextStyle": "dark"
      }
    },
    {
      "path": "pages/withdraw/index",
      "style": {
        "navigationBarTitleText": "提现",
        "enablePullDownRefresh": true,
        "backgroundTextStyle": "dark"
      }
    },
    {
      "path": "pages/submission-detail/index",
      "style": {
        "navigationBarTitleText": "提交详情",
        "enablePullDownRefresh": true,
        "backgroundTextStyle": "dark"
      }
    },
    {
      "path": "pages/feedback/index",
      "style": {
        "navigationBarTitleText": "意见反馈",
        "enablePullDownRefresh": true,
        "backgroundTextStyle": "dark"
      }
    },
    {
      "path": "pages/orders/index",
      "style": {
        "navigationBarTitleText": "我的接单",
        "enablePullDownRefresh": true,
        "backgroundTextStyle": "dark"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "诺斯马丁",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  },
  "tabBar": {
    "color": "#7A7E83",
    "selectedColor": "#3cc51f",
    "borderStyle": "black",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/index/index",
        "iconPath": "static/tabbar/task.png",
        "selectedIconPath": "static/tabbar/task-active.png",
        "text": "任务"
      },
      {
        "pagePath": "pages/my/index",
        "iconPath": "static/tabbar/my.png",
        "selectedIconPath": "static/tabbar/my-active.png",
        "text": "我的"
      }
    ]
  }
}


